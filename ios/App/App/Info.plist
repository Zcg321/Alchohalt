<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Alchohalt</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!--
	  [R6-B] Privacy usage descriptions.

	  Microphone + speech recognition are requested only when the user
	  taps the (currently flag-gated) voice-log button. Health share/
	  update is requested only when the user opts in to the (also flag-
	  gated) health integration. The strings ship even though the
	  optional Capacitor plugins are not installed in the default build,
	  so a future release that flips ENABLE_VOICE_LOGGING or
	  ENABLE_HEALTH_INTEGRATION won't get rejected by App Review for a
	  missing usage string.

	  Strings are written in plain language — they describe exactly what
	  the app does with the data, no marketing voice.
	-->
	<key>NSMicrophoneUsageDescription</key>
	<string>Alchohalt uses the microphone only when you tap the voice-log button to dictate a drink entry. Audio is converted to text on your device and never sent anywhere.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Speech recognition is used only when you tap the voice-log button. Recognition runs on your device — the audio and the transcript never leave your phone.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Alchohalt reads sleep, steps, and resting heart rate from Apple Health to show how your drinking patterns line up with the rest of your day. Reading is opt-in and you can revoke it anytime in Settings.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Alchohalt does not currently write to Apple Health. This permission is requested only if you opt in to a future feature that records alcohol intake back to Health.</string>
</dict>
</plist>
