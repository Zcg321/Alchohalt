node_modules
dist
coverage
stats.html

# binaries
*.png
*.jpg
*.jpeg
*.gif
!public/*.png

# logs
npm-debug.log*
*.log

!public/icons/*.png

# [R7-A2] Native launcher icons need to ship in the repo so iOS / Android
# build outputs are reproducible without running gen-icons on the build
# host. Source SVGs live at public/branding/icon-source/.
!ios/App/App/Assets.xcassets/**/*.png
!android/app/src/main/res/mipmap-*/*.png

# Health scan reports
repo_scan.json
repo_scan_human.txt
imports.dot
imports.png
deadcode_report.txt
deps_report.txt
size_report.txt
apk_size_report.txt
security_audit.txt
outdated_packages.txt
__pycache__/

# Local-only / per-developer state
.claude/
.env.local
.env.*.local

# PWA dev workbox output (regenerated on every `vite dev`)
dev-dist/

# Legal site build output (regenerated by tools/legal/build_site.py on Pages deploy)
_legal_site/

# Vitest/Vite config transform artifacts
vitest.config.*.timestamp-*.mjs
vite.config.*.timestamp-*.mjs

# [R7-A3] Playwright persona-walkthrough outputs (CI artifact only).
# The spec + fixtures live in e2e/ and are tracked; the rendered PNGs
# and reports are regenerated on every run.
e2e/screenshots/
playwright-report/
playwright-test-output/
test-results/

# Push helper scripts dropped by automation
_push_*.bat

# Auto-generated by tools/ensure_size_limit_config.js (file paths
# embed build hashes that churn on every commit)
.size-limit.cjs
